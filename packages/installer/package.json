{
  "name": "@pioneer-ui/installer",
  "version": "0.1.0",
  "description": "Safe file planning, diffing, and writes for Pioneer UI registry installs.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://Eselfin31.github.io/PioneerUI/",
  "bugs": {
    "url": "https://github.com/Eselfin31/PioneerUI/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eselfin31/PioneerUI.git",
    "directory": "packages/installer"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown src/index.ts --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@pioneer-ui/registry": "workspace:*",
    "@pioneer-ui/shared": "workspace:*",
    "ky": "2.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
